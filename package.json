{
  "name": "aws-tools",
  "version": "1.0.0",
  "description": "AWS Tools - Text Classifier/Summarizer and Notification Handler",
  "type": "module",
  "workspaces": [
    "shared",
    "classifier-summarizer",
    "notification-handler"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "classifier": "node classifier-summarizer/src/run.js",
    "notification": "node notification-handler/src/run.js"
  },
  "devDependencies": {
    "@types/node": "^24.4.2",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "dotenv": "^16.4.5",
    "openai": "^4.52.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "zod": "^3.23.8",
    "@google/generative-ai": "^0.13.0"
  }
}
